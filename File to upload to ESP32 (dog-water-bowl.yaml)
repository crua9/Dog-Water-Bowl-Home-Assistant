esphome:
  name: dog-water-bowl
  friendly_name: Dog Water Bowl
  area: Kitchen

esp32:
  board: esp32-c6-devkitc-1
  framework:
    type: esp-idf

wifi:
  ssid: !secret wifi_ssid
  password: !secret wifi_password
  power_save_mode: NONE
  manual_ip:
    static_ip: 
    gateway: 
    subnet: 
  on_connect:
    then:
      - script.execute: update_green_led

api:
  encryption:
    key: ""

ota:
  - platform: esphome
    password: ""

logger:
  level: DEBUG

# --- OUTPUTS (PWM for Dimming) ---
output:
  - platform: ledc
    pin: GPIO2   # D2 (Blue)
    id: blue_out
  - platform: ledc
    pin: GPIO21  # D3 (Red)
    id: red_out
  - platform: ledc
    pin: GPIO22  # D4 (Green)
    id: green_out
  - platform: ledc
    pin: GPIO23  # D5 (Yellow)
    id: yellow_out

# --- LIGHTS (Monochromatic for Dimming) ---
light:
  - platform: monochromatic
    name: "Blue LED"
    id: blue_led
    output: blue_out
    restore_mode: ALWAYS_OFF
  - platform: monochromatic
    name: "Red LED"
    id: red_led
    output: red_out
    restore_mode: ALWAYS_OFF
  - platform: monochromatic
    name: "Yellow LED"
    id: yellow_led_light
    output: yellow_out
    restore_mode: ALWAYS_OFF
  - platform: monochromatic
    name: "Green Status LED"
    id: green_led
    output: green_out
    restore_mode: ALWAYS_OFF

# --- AUTOMATION ENTITY ---
binary_sensor:
  - platform: template
    name: "Dog Bowl Needs Refill"
    id: refill_alarm
    device_class: problem

# --- TOGGLES ---
switch:
  - platform: template
    name: "Manual LED Override"
    id: manual_mode
    optimistic: true

  - platform: template
    name: "WiFi Status LED Switch"
    id: status_led_enable
    optimistic: true
    restore_mode: ALWAYS_ON
    on_turn_on:
      then:
        - script.execute: update_green_led
    on_turn_off:
      then:
        - light.turn_off: 
            id: green_led
            transition_length: !lambda "return id(fade_time).state * 1000;"

# --- CALIBRATION & ADJUSTMENTS ---
number:
  - platform: template
    name: "Calibrate: Empty Bowl"
    id: empty_val
    mode: box
    step: 0.001
    min_value: 0
    max_value: 3.3
    optimistic: true
    restore_value: true

  - platform: template
    name: "Calibrate: Blue LED"
    id: full_val
    mode: box
    step: 0.001
    min_value: 0
    max_value: 3.3
    optimistic: true
    restore_value: true

  - platform: template
    name: "Stability Buffer"
    id: buffer_val
    mode: box
    unit_of_measurement: "V"
    step: 0.001
    min_value: 0
    max_value: 1.0
    optimistic: true
    restore_value: true
    initial_value: 0.050

  - platform: template
    name: "LED Brightness"
    id: led_bright
    mode: box
    unit_of_measurement: "%"
    step: 1
    min_value: 0
    max_value: 100
    optimistic: true
    restore_value: true
    initial_value: 50
    on_value:
      then:
        - script.execute: update_led_logic
        - script.execute: update_green_led

  - platform: template
    name: "LED Fade Time"
    id: fade_time
    mode: box
    unit_of_measurement: "s"
    step: 0.1
    min_value: 0
    max_value: 10
    optimistic: true
    restore_value: true
    initial_value: 1.0

  - platform: template
    name: "Report Interval"
    id: report_freq
    mode: box
    unit_of_measurement: "s"
    step: 0.1
    min_value: 0.1
    max_value: 60
    optimistic: true
    restore_value: true

# --- SENSORS ---
sensor:
  - platform: adc
    pin: GPIO1 
    id: raw_adc
    update_interval: 200ms
    attenuation: 12db
    filters:
      - median:
          window_size: 30
          send_every: 1
      - sliding_window_moving_average:
          window_size: 15
          send_every: 1
    on_value:
      then:
        - lambda: |-
            static uint32_t last_millis = 0;
            uint32_t now = millis();
            if (now - last_millis >= (id(report_freq).state * 1000)) {
              
              // Ensure Green LED stays synced with brightness/status
              id(update_green_led).execute();

              float raw_v = id(raw_adc).state; 
              float low = id(empty_val).state;
              float high = id(full_val).state;
              
              float pct = ((raw_v - low) / (high - low)) * 100.0;
              id(water_pct_ha).publish_state(clamp(pct, 0.0f, 100.0f));
              id(raw_val_ha).publish_state(raw_v);
              id(refill_alarm).publish_state(raw_v < low);
              
              id(update_led_logic).execute();
              
              last_millis = now;
            }

  - platform: template
    name: "Water Percentage"
    id: water_pct_ha
    unit_of_measurement: "%"

  - platform: template
    name: "Raw Weight Value"
    id: raw_val_ha

# --- THE WEIGHT BRAIN ---
script:
  - id: update_green_led
    then:
      - if:
          condition:
            lambda: 'return id(status_led_enable).state;'
          then:
            - light.turn_on:
                id: green_led
                brightness: !lambda "return id(led_bright).state / 100.0;"
                transition_length: !lambda "return id(fade_time).state * 1000;"
          else:
            - light.turn_off:
                id: green_led
                transition_length: !lambda "return id(fade_time).state * 1000;"

  - id: update_led_logic
    mode: restart
    then:
      - if:
          condition:
            lambda: 'return !id(manual_mode).state;'
          then:
            - lambda: |-
                float raw = id(raw_adc).state;
                float empty = id(empty_val).state;
                float full = id(full_val).state;
                float buffer = id(buffer_val).state;
                float b_level = id(led_bright).state / 100.0;
                float f_ms = id(fade_time).state * 1000.0;

                bool is_blue = id(blue_led).remote_values.is_on();
                bool is_red = id(red_led).remote_values.is_on();

                if (raw > (is_blue ? full : full + buffer)) {
                  auto call = id(blue_led).turn_on();
                  call.set_brightness(b_level);
                  call.set_transition_length(f_ms);
                  call.perform();
                  id(yellow_led_light).turn_off().set_transition_length(f_ms).perform();
                  id(red_led).turn_off().set_transition_length(f_ms).perform();
                } 
                else if (raw < (is_red ? empty + buffer : empty)) {
                  id(blue_led).turn_off().set_transition_length(f_ms).perform();
                  id(yellow_led_light).turn_off().set_transition_length(f_ms).perform();
                  auto call = id(red_led).turn_on();
                  call.set_brightness(b_level);
                  call.set_transition_length(f_ms);
                  call.perform();
                } 
                else {
                  id(blue_led).turn_off().set_transition_length(f_ms).perform();
                  auto call = id(yellow_led_light).turn_on();
                  call.set_brightness(b_level);
                  call.set_transition_length(f_ms);
                  call.perform();
                  id(red_led).turn_off().set_transition_length(f_ms).perform();
                }
